UNTIS_URL=https://deineschule.webuntis.com
UNTIS_SCHOOL=Schulname wie in WebUntis
UNTIS_SCHOOL_ID=sXXXXXX
SHOW_TOMORROW_AFTER=12:30
UNTIS_USER=dein-benutzer
UNTIS_PASSWORD=dein-passwort
# Abteilungs-Filter für getSubstitutions. 0 = alle Abteilungen (Default).
# Nur ändern, wenn eure Schule WebUntis-Abteilungen nutzt und ihr nur eine wollt.
UNTIS_DEPARTMENT_ID=0

# Logo anzeigen? true = Logo-Datei aus dem Projektordner wird verwendet, false = kein Logo
SHOW_LOGO=false
# Dateiname des Logos (im Projekt-Root). PNG/SVG/JPG/WebP möglich.
LOGO_FILE=logo.png

# ── WebUntis-Feinjustierung (schul-spezifisch) ───────────────
# SKIP_TEACHERS: schul-eigene Pseudo-Lehrer aus den Untis-Stammdaten, die wie "---"
#   behandelt werden. Komma-getrennt. "---" und Leerzeichen sind immer ausgenommen.
#   WICHTIG: Der Pseudo-Name selbst wird nie angezeigt, dient aber als MARKER für den
#   echten abwesenden Lehrer: trägt der Eintrag eine orgid+orgname, wird dieser echte
#   Lehrer ausgelesen und gezeigt — durchgestrichen vor dem Vertreter (SaF→BuL) bzw.
#   in der "Entfallende Stunden"-Sektion und in der "Abwesende Lehrer"-Leiste.
#   Nur ohne orgid/orgname (kein Lehrer-Verweis) wird der Eintrag ganz verworfen.
#   Beispiel hier: der Pseudo-Lehrer "Z Entfall".
SKIP_TEACHERS=Z Entfall
# TEXT_BADGES: Bemerkungs-Codes, die als farbiges Kürzel-Badge gerendert werden
#   (statt als reiner Text). Komma-getrennt. Bekannte Codes b/ub/MA haben eigene
#   Farben, weitere bekommen ein neutrales Badge. Leer/weglassen = Default b,ub,MA.
TEXT_BADGES=b,ub,MA
# PLAN_TITLE: Überschrift/Titel des Plans ("Supplierplan", "Vertretungsplan", …).
#   Erscheint in Browser-Titel, Sub-Header-Label, Leer-Meldungen und PWA-Manifest.
PLAN_TITLE=Supplierplan

# ── Schul-Bezeichnung (Header + Footer + Browser-Titel) ──────
# SCHOOL_NAME      → große Überschrift im Header, Footer rechts und Browser-Titel
# SCHOOL_TYPE      → erste Hälfte der grauen Sub-Zeile (z.B. Schulform)
# SCHOOL_LOCATION  → zweite Hälfte der Sub-Zeile + Footer (z.B. PLZ + Ort)
# Sub-Zeile  = "SCHOOL_TYPE · SCHOOL_LOCATION"
# Footer     = "SCHOOL_NAME · SCHOOL_LOCATION"
# Leere Werte fallen automatisch aus der " · "-Kette.
SCHOOL_NAME=Beispielschule
SCHOOL_TYPE=Mittelschule
SCHOOL_LOCATION=PLZ Ort

# ── Farbschema (Dark/Light) ──────────────────────────────────
# THEME=dark (Standard) oder THEME=light. Gilt für den gesamten Supplierplan.
# In der Mobil-Ansicht (≤600px) kann ein kleiner Schalter oben links das Theme
# pro Gerät überschreiben (gespeichert im Browser). Breit-/Schmal-Ansicht
# folgen ausschließlich dieser Einstellung.
THEME=dark

# ── PWA-Orientierung (Handy/Tablet als installierte App) ─────
# PWA_ORIENTATION steuert, in welche Bildschirm-Orientierung sich die als PWA
# installierte App sperrt. Default "any" = Gerät darf frei drehen.
#   any (Standard) · portrait · landscape · natural
# Wichtig: Ein fest montierter Monitor/TV dreht ohnehin nie — ihm ist der Wert
# egal. Die Sperre betrifft NUR drehbare Geräte (Handy, Tablet-Kiosk). Wer am
# Handy frei drehen will, lässt "any" stehen. Ungültige Werte → "any".
PWA_ORIENTATION=any

# ── Uhr / Datum + Zeitzone ───────────────────────────────────
# SHOW_CLOCK=false blendet Datum + Uhrzeit im Header komplett aus (inkl. Trennlinie).
SHOW_CLOCK=true
# Zeitzone für "heute/morgen"-Berechnung UND die Uhr-Anzeige (IANA-Name).
# Beispiele: Europe/Vienna, Europe/Berlin, Europe/Zurich. Default: Europe/Vienna.
# Hinweis: Auf Windows ggf. "pip install tzdata" nötig, sonst Fallback auf System-TZ.
TIMEZONE=Europe/Vienna

# ── Cloudflare Cache-Purge (optional) ────────────────────────
# Wird automatisch nach jedem Cron-Run aufgerufen, sobald beide Werte gesetzt sind.
# Token erzeugen:  dash.cloudflare.com → My Profile → API Tokens → Create Token
#                  Template "Edit zone DNS" reicht NICHT - eigene Permission "Zone:Cache Purge"
# Zone-ID:         dash.cloudflare.com → Domain auswählen → unten rechts "API → Zone ID"
# CLOUDFLARE_HOST: optional. Wenn gesetzt, wird NUR dieser Hostname gepurged
#                  (sicher, falls Domain noch andere Inhalte hat).
#                  Nur FQDN, KEIN https:// und KEIN / am Ende, z.B.:
#                    CLOUDFLARE_HOST=supplierplan.example.tld
#                  Leer lassen für "purge everything" (gesamte Zone).
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_HOST=

# ── Zug-Widget (optional) ────────────────────────────────────
# Wenn TRAIN_STATION leer ist, wird das Widget nicht ins HTML eingebaut.
# Eigener Cron-Job alle 60s ruft scripts/fetch_trains.py auf - schreibt data/trains.json.
TRAIN_STATION=
# WICHTIG: nur eindeutige, vollständige Bahnhofs-Namen verwenden! Ein Kürzel wie "Hbf"
# allein matcht mehrere Bahnhöfe und würde die Richtung falsch klassifizieren.
TRAIN_DIR_TOWARDS=Beispielstadt Hbf,Beispielstadt Nord
TRAIN_PER_DIRECTION=1
TRAIN_DISABLED=false
# Welche Produkte (Linien-Präfixe) anzeigen? Komma-getrennt.
# Beispiele:
#   TRAIN_PRODUCTS=S            → nur S-Bahnen (matcht "S 3", "S 50")
#   TRAIN_PRODUCTS=S,REX,R      → S-Bahn + REX + Regional
#   TRAIN_PRODUCTS=             → alles (inkl. Bus, U-Bahn, Tram)
TRAIN_PRODUCTS=S

# Compact-Mode: ab welcher Spaltenbreite (in Pixel) die Art-Badges
# rund werden und "Aufsicht" auf "Aufs." gekürzt wird. Default: 320.
COMPACT_COL_WIDTH_PX=320

# Maximale Spaltenanzahl im Multi-Column-Layout (1-4). Default: 4.
# Niedriger setzen, wenn breitere Spalten gewünscht sind (z.B. 2 oder 3).
MAX_COLUMNS=4

# ── Überlauf-Strategie (Monitor zu voll) ──
# Greift nur bei echtem Überlauf; an normalen Tagen passiert nichts.
# Reihenfolge: Skalieren -> Reduzieren -> Blättern. "Morgen" bleibt immer sichtbar.
# WICHTIG: KEINE Inline-Kommentare hinter die Werte schreiben (werden Teil des Werts).
# Stufe 1: alles verkleinern bis Mindestgröße
OVERFLOW_SCALE=true
# kleinster Skalierungsfaktor (0.65 = 65 %), Bereich 0.3–1.0
OVERFLOW_SCALE_MIN=0.65
# Stufe 2: Text-Spalte aus, dann Entfall-Sektion kompakt
OVERFLOW_REDUCE=true
# Stufe 3: überlaufende Sektion blättert seitenweise
OVERFLOW_PAGINATE=true
# Sekunden pro Seite beim Blättern (min. 3)
OVERFLOW_PAGE_SECONDS=12

# ── Lokaler Server (Windows-Tray-App) ──
# Port des lokalen Webservers im LAN
SERVER_PORT=8080
# Wie oft die Untis-Daten geholt werden (Sekunden)
UNTIS_INTERVAL_SECONDS=300
# Wie oft die Zug-Daten geholt werden (Sekunden)
TRAIN_INTERVAL_SECONDS=60
